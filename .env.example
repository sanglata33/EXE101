# ============================================================
# FreshWash — Example Environment Variables (commit file này lên Git)
# ============================================================
# Sao chép file này thành .env và điền giá trị thật

# URL gốc của Backend API
VITE_API_BASE_URL=http://localhost:5000/api

# Timeout cho mỗi request (ms)
VITE_API_TIMEOUT=10000
